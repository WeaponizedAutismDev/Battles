{
  "$schema": "https://design-tokens.github.io/schema.json",
  "tokenSetOrder": ["core", "semantic"],
  "core": {
    "color": {
      "bg": { "value": "#0E1014" },
      "text": { "value": "#E2E8F0" },
      "muted": { "value": "#6B7280" },
      "accent": { "value": "#00FFD1" },
      "danger": { "value": "#FF3344" },
      "heat": { "value": "#FF7A00" },
      "shield": { "value": "#3DA5FF" },
      "gold": { "value": "#F5C542" },
      "purple": { "value": "#A46BFF" }
    },
    "font": {
      "display": { "value": "Oxide Mono" },
      "ui": { "value": "Inter" },
      "size": {
        "xs": { "value": 12 },
        "sm": { "value": 14 },
        "md": { "value": 16 },
        "lg": { "value": 20 },
        "xl": { "value": 24 },
        "2xl": { "value": 32 }
      },
      "weight": {
        "regular": { "value": 400 },
        "semibold": { "value": 600 },
        "bold": { "value": 700 }
      }
    },
    "size": {
      "spacing": { "value": [0,4,8,12,16,24,32,48,64] },
      "icon": {
        "sm": { "value": 16 },
        "md": { "value": 20 },
        "lg": { "value": 24 }
      }
    },
    "radius": { "sm": { "value": 4 }, "md": { "value": 8 }, "lg": { "value": 12 } },
    "shadow": {
      "hud": { "value": "0 2px 8px rgba(0,0,0,0.35)" },
      "elevated": { "value": "0 6px 24px rgba(0,0,0,0.45)" }
    },
    "motion": {
      "fast": { "value": "120ms" },
      "normal": { "value": "200ms" },
      "overshoot": { "value": "cubic-bezier(.18,.89,.32,1.28)" }
    }
  },
  "semantic": {
    "color": {
      "hud.bg": { "value": "{core.color.bg}" },
      "hud.text": { "value": "{core.color.text}" },
      "hud.accent": { "value": "{core.color.accent}" },
      "hud.danger": { "value": "{core.color.danger}" },
      "hud.heat": { "value": "{core.color.heat}" },
      "hud.shield": { "value": "{core.color.shield}" }
    },
    "component": {
      "button.radius": { "value": "{core.radius.md}" },
      "card.radius": { "value": "{core.radius.lg}" },
      "hud.shadow": { "value": "{core.shadow.hud}" }
    }
  }
}